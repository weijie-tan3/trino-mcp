{
  "servers": {
    "trino-local-test-mcp": {
      "command": "uv",
      "args": ["run", "--extra", "azure", "trino-mcp", "--query-timeout-minutes", "10"],
      // "cwd": "${workspaceFolder}",
      "env": {
        "TRINO_MCP_CUSTOM_WATERMARK": "{\"weijie-test-tag\": \"cancel-trino-query-by-timeout\"}",
      }
    },
    "github-mcp": {
        "type": "http",
        "url": "https://api.githubcopilot.com/mcp/"
    }
  }
}
