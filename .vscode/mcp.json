{
  "servers": {
    "trino-local-test-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": ["run", "--extra", "azure", "trino-mcp", "--query-timeout-minutes", "0.2"],
      "cwd": "${workspaceFolder}",
      "env": {
        "TRINO_MCP_CUSTOM_WATERMARK": "{\"dummy\": \"env:RUN_ENV_VAR\", \"ANOTHER_VAR_FROM_ENV\": \"OSLogRateLimit\"}",
        "RUN_ENV_VAR": "RUN_ENV_VAR_VALUE_1"
      }
    },
    "github-mcp": {
        "type": "http",
        "url": "https://api.githubcopilot.com/mcp/"
    }
  }
}
